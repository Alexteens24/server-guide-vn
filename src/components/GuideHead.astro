---
import DefaultHead from '@astrojs/starlight/components/Head.astro';
import guide from '../data/guide-pages.json';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const route = Astro.locals.starlightRoute;
const data = route.entry.data;
const normalizedPath = Astro.url.pathname.replace(base, '').replace(/^\/+|\/+$/g, '');
const imageUrl = new URL(`${base}og-guide.png`, Astro.site ?? Astro.url).href;
const sourceUrl = 'https://minevn.net/threads/lo-trinh-huong-dan-phat-trien-toi-uu-hieu-nang-may-chu-minecraft-danh-cho-nguoi-moi.52423/';
const isHome = normalizedPath === '';
const canonical = Astro.url.href;
const description = data.description ?? 'Lộ trình phát triển, vận hành và tối ưu máy chủ Minecraft.';

const structuredData = isHome
  ? {
      '@context': 'https://schema.org',
      '@type': 'TechArticle',
      headline: 'Lộ trình Server Minecraft',
      url: canonical,
      inLanguage: 'vi',
      description,
      image: imageUrl,
      datePublished: '2026-04-22',
      dateModified: guide.verifiedAt,
      author: { '@type': 'Person', name: 'Minh — TranNhatMinhxD' },
      isBasedOn: sourceUrl,
      license: 'https://creativecommons.org/licenses/by/4.0/',
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: data.title,
      description,
      url: canonical,
      inLanguage: 'vi',
    };
---

<DefaultHead />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Lộ trình Server Minecraft — tài liệu tiếng Việt" />
<meta name="twitter:image" content={imageUrl} />
<meta name="theme-color" content="#15803d" />
<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
