---
import guide from '../data/guide-pages.json';
import fragmentManifest from '../data/chapter-fragments.json';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const pages = guide.pages;
const mainPages = pages.filter((page) => !page.parent);
const statsByPage = new Map(mainPages.map((page) => {
  const children = pages.filter((item) => item.parent === page.id);
  const fragmentIds = [page.fragment, ...children.map((item) => item.fragment)].filter(Boolean);
  const stats = fragmentManifest.items
    .filter((fragment) => fragmentIds.includes(fragment.id))
    .reduce((total, fragment) => ({
      chars: total.chars + fragment.textLength,
      topics: total.topics + fragment.headings,
    }), { chars: 0, topics: 0 });
  return [page.id, stats];
}));
---

<section class="chapter-directory" aria-labelledby="chapter-directory-title">
  <header>
    <div><span>Tài liệu hoàn chỉnh</span><h2 id="chapter-directory-title">Chọn chương để bắt đầu</h2></div>
    <p>Mỗi chương có URL riêng, mục lục riêng và ghi chú phiên bản ở cuối mục.</p>
  </header>
  <ol>
    {mainPages.map((page) => {
      const stats = statsByPage.get(page.id);
      const children = pages.filter((item) => item.parent === page.id).length;
      return (
        <li>
          <a href={`${base}${page.slug}/`}>
            <span class="chapter-directory__number">{page.number}</span>
            <div><strong>{page.title}</strong><p>{page.description}</p></div>
            <small>{stats?.topics ?? 0} đề mục{children ? ` · ${children} trang con` : ''}</small>
            <i aria-hidden="true">→</i>
          </a>
        </li>
      );
    })}
  </ol>
  <a class="chapter-directory__archive" href={`${base}nguyen-tac/`}>
    <span><strong>Kho nguyên tác</strong><small>Toàn bộ bài đăng trong một trang, không lược bỏ nội dung</small></span>
    <i aria-hidden="true">Mở archive →</i>
  </a>
</section>
