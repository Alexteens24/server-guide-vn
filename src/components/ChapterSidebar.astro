---
import guide from '../data/guide-pages.json';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const normalizedPath = Astro.url.pathname
  .replace(base, '')
  .replace(/^\/+|\/+$/g, '');
const pages = guide.pages;
const chapters = pages.filter((page) => !page.parent);
const activePage = pages.find((page) => page.slug === normalizedPath);
const activeChapterId = activePage?.parent ?? activePage?.id;
const hrefFor = (slug: string) => `${base}${slug}/`;
---

<nav class="chapter-sidebar" aria-label="Các chương trong lộ trình">
  <div class="chapter-sidebar__head">
    <span class="chapter-sidebar__eyebrow">Navigation</span>
    <a class="chapter-sidebar__home" href={base} aria-current={!normalizedPath ? 'page' : undefined}>Lộ trình hoàn chỉnh</a>
    <p>Bắt đầu từ hệ thống, kết thúc ở trải nghiệm người chơi.</p>
  </div>
  <ol>
    {chapters.map((chapter) => {
      const children = pages.filter((page) => page.parent === chapter.id);
      const expanded = activeChapterId === chapter.id;
      return (
      <li class:list={{ 'is-active': expanded }}>
        <a href={hrefFor(chapter.slug)} aria-current={activePage?.id === chapter.id ? 'page' : undefined}>
          <span class="chapter-sidebar__number">{chapter.number}</span>
          <span><strong>{chapter.title}</strong><small>{chapter.description}</small></span>
        </a>
        {children.length > 0 && expanded && (
          <ol class="chapter-sidebar__children">
            {children.map((child) => (
              <li>
                <a href={hrefFor(child.slug)} aria-current={activePage?.id === child.id ? 'page' : undefined}>
                  <span class="chapter-sidebar__number">{child.number}</span>
                  <span><strong>{child.title}</strong></span>
                </a>
              </li>
            ))}
          </ol>
        )}
      </li>
      );
    })}
  </ol>
  <div class="chapter-sidebar__foot">
    <span><i></i> Nội dung đã biên tập</span>
    <a
      class="chapter-sidebar__source"
      href={`${base}nguyen-tac/`}
    >
      Kho nguyên tác ↗
    </a>
  </div>
</nav>
