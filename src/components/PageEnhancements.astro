<div class="scroll-progress" aria-hidden="true"><span></span></div>
<a class="back-to-top" href="#_top" aria-label="Về đầu trang" title="Về đầu trang">
  <span aria-hidden="true">↑</span>
</a>

<script>
  function copyText(value: string) {
    if (navigator.clipboard?.writeText) return navigator.clipboard.writeText(value);
    return Promise.reject(new Error('Clipboard API không khả dụng'));
  }

  function enhanceOriginalPost() {
    const article = document.querySelector<HTMLElement>('.original-post');
    if (!article || article.dataset.enhanced === 'true') return;
    article.dataset.enhanced = 'true';

    article.querySelectorAll('.bbCodeBlock--code').forEach((block) => {
      const code = block.querySelector('code');
      const title = block.querySelector('.bbCodeBlock-title');
      if (!code || !title) return;

      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'original-code-copy';
      button.textContent = 'Sao chép';
      button.setAttribute('aria-label', 'Sao chép đoạn mã');
      button.addEventListener('click', async () => {
        try {
          await copyText(code.textContent || '');
          button.textContent = 'Đã chép ✓';
        } catch {
          button.textContent = 'Không thể chép';
        }
        window.setTimeout(() => { button.textContent = 'Sao chép'; }, 1800);
      });
      title.append(button);
    });

    article.querySelectorAll('.bbTable').forEach((table, index) => {
      table.setAttribute('role', 'region');
      table.setAttribute('tabindex', '0');
      table.setAttribute('aria-label', `Bảng dữ liệu ${index + 1} — có thể cuộn ngang`);
    });
  }

  function enhancePage() {
    enhanceOriginalPost();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', enhancePage, { once: true });
  } else {
    enhancePage();
  }
</script>
