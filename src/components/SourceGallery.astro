---
import manifest from '../data/media.json';

interface Props {
  from?: number;
  to?: number;
  title?: string;
}

const { from = 1, to = Number.POSITIVE_INFINITY, title } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const items = manifest.items.filter(
  (item) => item.order >= from && item.order <= to && item.status === 'downloaded' && item.filename,
);
const regular = items.filter((item) => !item.decorative);
const decorative = items.filter((item) => item.decorative);
const isOpenByDefault = items.length <= 12;
---

{items.length > 0 && (
  <details class="source-media" open={isOpenByDefault}>
    <summary>
      <span class="source-media__icon" aria-hidden="true">▦</span>
      <span class="source-media__heading">
        <strong>{title ?? 'Ảnh minh họa từ bài nguồn'}</strong>
        <small>{items.length} media · bấm để {isOpenByDefault ? 'thu gọn' : 'mở thư viện'}</small>
      </span>
      <span class="source-media__count">{items.length}</span>
      <span class="source-media__chevron" aria-hidden="true">⌄</span>
    </summary>
    <div class="source-media__body">
      {regular.length > 0 && (
        <div class="source-gallery">
          {regular.map((item) => (
            <figure>
              <a href={`${base}media/source/${item.filename}`} target="_blank" rel="noreferrer">
                <span class="source-gallery__frame">
                  <img
                    src={`${base}media/source/${item.filename}`}
                    alt={item.alt}
                    width={item.width ?? undefined}
                    height={item.height ?? undefined}
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="source-gallery__zoom" aria-hidden="true">↗</span>
                  {item.contentType === 'image/gif' && <span class="source-gallery__type">GIF</span>}
                </span>
              </a>
              <figcaption>{item.alt}</figcaption>
            </figure>
          ))}
        </div>
      )}
      {decorative.length > 0 && (
        <div class="source-emojis" aria-label="Meme và biểu cảm từ bài nguồn">
          <span>Biểu cảm</span>
          {decorative.map((item) => (
            <a href={`${base}media/source/${item.filename}`} target="_blank" rel="noreferrer">
              <img
                src={`${base}media/source/${item.filename}`}
                alt={item.alt}
                title={item.title || item.alt}
                loading="lazy"
                decoding="async"
              />
            </a>
          ))}
        </div>
      )}
      <p class="media-credit">
        Media từ <a href={manifest.source} target="_blank" rel="noreferrer">bài viết gốc của Minh</a>.
      </p>
    </div>
  </details>
)}
