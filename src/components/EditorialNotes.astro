---
import notesData from '../data/editorial-notes.json';

interface Props { pageId: string; }
const { pageId } = Astro.props;
const notes = notesData.notes[pageId as keyof typeof notesData.notes] ?? [];
const labels = {
  confirmed: 'Đã kiểm chứng',
  version: 'Phụ thuộc phiên bản',
  caution: 'Cần thận trọng',
  author: 'Quan điểm tác giả',
} as const;
---

{notes.length > 0 && (
  <aside class="editorial-notes" aria-labelledby={`editorial-notes-${pageId}`}>
    <header>
      <div>
        <span>Biên tập · kiểm tra {notesData.checkedAt}</span>
        <h2 id={`editorial-notes-${pageId}`}>Ghi chú sau mục</h2>
      </div>
      <small>{notes.length} ghi chú</small>
    </header>
    <div class="editorial-notes__list">
      {notes.map((note) => (
        <section class:list={['editorial-note', `editorial-note--${note.status}`]}>
          <div class="editorial-note__meta">
            <span>{labels[note.status as keyof typeof labels]}</span>
            {'version' in note && note.version && <small>{note.version}</small>}
          </div>
          <h3>{note.title}</h3>
          <p>{note.body}</p>
          {'sources' in note && note.sources && (
            <div class="editorial-note__sources">
              <span>Nguồn:</span>
              {note.sources.map((source) => (
                <a href={source.href} target="_blank" rel="noreferrer">{source.label} ↗</a>
              ))}
            </div>
          )}
        </section>
      ))}
    </div>
  </aside>
)}
