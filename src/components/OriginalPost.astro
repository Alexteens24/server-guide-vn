---
import originalPost from '../data/original-post.html?raw';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const html = originalPost.replaceAll('__BASE__', base);
---

<article class="original-post" aria-label="Toàn bộ nội dung gốc bài đăng MineVN" set:html={html} />
