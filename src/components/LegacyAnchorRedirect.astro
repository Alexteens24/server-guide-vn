---
import fragmentManifest from '../data/chapter-fragments.json';
import guide from '../data/guide-pages.json';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const pageByFragment = new Map(
  guide.pages.filter((page) => page.fragment).map((page) => [page.fragment, page]),
);
const legacyMap: Record<string, string> = {};
for (const fragment of fragmentManifest.items) {
  const page = pageByFragment.get(fragment.id);
  if (!page) continue;
  for (const anchor of fragment.anchors) {
    legacyMap[anchor] = `${base}${page.slug}/${anchor === fragment.firstHeadingId ? '' : `#${anchor}`}`;
  }
}
for (const page of guide.pages.filter((item) => !item.parent)) {
  legacyMap[page.id] = `${base}${page.slug}/`;
}
---

<script is:inline define:vars={{ legacyMap }}>
  const anchor = decodeURIComponent(window.location.hash.slice(1));
  if (anchor && legacyMap[anchor]) window.location.replace(legacyMap[anchor]);
</script>
